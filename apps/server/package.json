    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.2",
    "@types/nodemailer": "^8.0.0",
    "@upstash/redis": "^1.38.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
