{
  "name": "server",
  "version": "1.0.0",
  "main": "server.ts",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "dev": "cross-env NODE_ENV=dev tsx watch src/server.ts",
    "build": "tsc && tsc-alias && npm run copy:prisma",
    "copy:prisma": "node -e \"const fs=require('fs');fs.rmSync('dist/generated',{recursive:true,force:true});fs.cpSync('src/generated','dist/generated',{recursive:true})\"",
    "start": "cross-env NODE_ENV=prod node dist/server.js",
    "start:prod": "npm run build && npm run start",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "db:init": "cross-env NODE_ENV=dev npx prisma init",
    "db:migrate": "cross-env NODE_ENV=dev dotenv -e .env.dev -- npx prisma migrate dev --schema=./prisma/schema",
    "db:generate": "cross-env NODE_ENV=dev dotenv -e .env.dev -- npx prisma generate --schema=./prisma/schema",
    "db:migrate:prod": "cross-env NODE_ENV=prod dotenv -e .env.prod -- npx prisma migrate deploy --schema=./prisma/schema",
    "db:generate:prod": "cross-env NODE_ENV=prod dotenv -e .env.prod -- npx prisma generate --schema=./prisma/schema",
    "db:studio": "dotenv -e .env.dev -- npx prisma studio --schema=./prisma/schema",
    "db:seed": "dotenv -e .env.dev -- tsx prisma/seed.ts",
    "db:seed:prod": "dotenv -e .env.prod -- tsx prisma/seed.ts",
    "db:reset": "dotenv -e .env.dev -- npx prisma migrate reset --schema=./prisma/schema",
    "db:push": "dotenv -e .env.dev -- npx prisma db push --schema=./prisma/schema",
    "db:deploy": "dotenv -e .env.dev -- npx prisma migrate deploy --schema=./prisma/schema"
  },
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1045.0",
    "@aws-sdk/lib-storage": "^3.1045.0",
    "@prisma/client": "^7.8.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.2",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@upstash/redis": "^1.38.0",
    "@vitest/coverage-v8": "^4.1.7",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv-cli": "^11.0.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.1",
    "helmet": "^8.1.0",
    "install": "^0.13.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.7",
    "npm": "^11.14.1",
    "prisma": "^7.8.0",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "supertest": "^7.2.2",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.7",
    "winston": "^3.19.0",
    "winston-cloudwatch": "^6.3.0",
    "zod": "^4.4.3"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "cloudinary": "^2.10.0",
    "compression": "^1.8.1",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "google-auth-library": "^10.6.2",
    "mongoose": "^9.6.2",
    "pg": "^8.20.0",
    "resend": "^6.12.4",
    "winston-daily-rotate-file": "^5.0.0"
  }
}
