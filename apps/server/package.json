{
  "name": "server",
  "version": "1.0.0",
  "main": "server.ts",
  "type": "module",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "cross-env NODE_ENV=dev tsx watch src/server.ts",
    "build": "tsc && tsc-alias",
    "start": "cross-env NODE_ENV=prod node dist/server.js",
    "start:prod": "npm run build && npm run start",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "db:init": "cross-env NODE_ENV=dev npx prisma init",
    "db:migrate": "cross-env NODE_ENV=dev npx prisma migrate dev",
    "db:generate": "cross-env NODE_ENV=dev npx prisma generate",
    "db:init:prod": "cross-env NODE_ENV=prod npx prisma init ",
    "db:migrate:prod": "cross-env NODE_ENV=prod npx prisma migrate dev ",
    "db:generate:prod": "cross-env NODE_ENV=prod npx prisma generate ",
    "db:deploy:prod": "cross-env NODE_ENV=prod npx prisma migrate deploy",
    "db:seed:prod": "cross-env NODE_ENV=prod node prisma/seed.js",
    "db:studio": "npx prisma studio",
    "db:seed": "node prisma/seed.js",
    "db:reset": "npx prisma migrate reset",
    "db:push": "npx prisma db push",
    "db:deploy": "npx prisma migrate deploy"
  },
