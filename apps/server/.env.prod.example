NODE_ENV=prod
PORT=5000

# Database
DATABASE_URL="postgresql://..."

# JWT (use strong random secrets in prod)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Google OAuth
GOOGLE_CLIENT_ID=

# Email (Resend)
RESEND_API_KEY=re_
EMAIL_FROM="withSell <noreply@yourdomain.com>"

# App
CLIENT_URL=https://yourdomain.com
ADMIN_EMAIL=

# Cloudinary (not used in prod — S3 is used instead)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# AWS S3
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=sell-karo-images
